int CalculateFinalDamage(int attack, int defense, float multiplier)   //
{
    int baseDamage = attack - defense;                                // +1 asignacion +1 disminución
    int finalDamage = (int)(baseDamage * multiplier);                 // +1 asignacion +1 o.aritmetica
 
    if(finalDamage < 0)                                               // +1 asignacion
    {
        finalDamage = 0;                                              // +1 asignación
    }

    return finalDamage;                                               // +1 
}

Procedimiento:       T(M) = 1+1+1+1+1+1+1
                     T(M) = 7

                     O(N) = 1
