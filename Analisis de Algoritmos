int CountStrongerPairs (int[] powerLevels)               // powerLevels seria la N
{
    int count = 0;                                       // +1 asignacion

    for (int i= 0; i< powerLevels.Length; i++)           // +1 asignacion + (N+1 Comparaciones) + N incrementos
    {
        for (int j = 0; j < powerLevels.Length; j++)     // +1 asignacion + (N+1 Comparaciones) + N incrementos
        {
            if ( powerLevels[i] > powerLevels[j])        // +1 indice +1 Comparación +1 indice
            {
                count++;                                 // +1 por ejecucion -> +N por cada ejecucion completa del for interno
            }

        }

    }
    return count;                                        // +1
}

                        Interior del for                              Exterior del for
Procedimiento:        T(M) = 1+(N+1)+N+1+1+1+1+N                  T(M) = 1+1+(N+1)+N+3N²+6N+1
                      T(M) = 3N+6                                 T(M) = 3N²+ 8N + 4
                      T(M) = N(3N+6)
                      T(M) = 3N²+6N                               0(N) = N²


                                    RPTA: T(M) = 3N²+ 8N + 4
                                    0(N) = N²
