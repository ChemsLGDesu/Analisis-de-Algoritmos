bool CanCastSpell ( int mana, int cost)
{
    int remainingMana = mana - cost;                               // +1 asignacion y +1 o.aritmetica
    if (remainingMana >= 0)                                        // +2 comparacion y asignación
    {
        Debug.Log("Spell casted");                                 // +1 llaamada simple
        return true;                                               // +1 
    }

    return false;                                                  // +1
}


